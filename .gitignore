# ============================================
# YOLO Object Detector - .gitignore
# ============================================

# ===== GENERAL =====
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ===== PYTHON (Backend & Functions) =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
*.log

# ===== DART / FLUTTER (Mobile) =====
# Build outputs
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/.pub-cache/
**/.pub/
/build/
*.app_state

# Generated files
*.g.dart
*.freezed.dart
*.config.dart

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws

# iOS
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/app.flx
**/ios/Flutter/app.zip
**/ios/Flutter/flutter_assets/
**/ios/ServiceDefinitions.json
**/ios/Runner/GeneratedPluginRegistrant.*

# Android
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks

# ===== FIREBASE =====
# Firebase config files (KEEP GITIGNORED FOR SECURITY)
**/google-services.json
**/GoogleService-Info.plist
**/.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
# Firebase (Sensitive files)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/firebase_options.dart
ios/firebase_app_id_file.json

# Functions
functions/node_modules/
functions/.env
functions/.env.yaml
functions/.secret.local
.firebaserc

# ===== DOCKER =====
# Don't ignore Dockerfile, but ignore build artifacts
*.log

# ===== MODELS =====
# YOLO models are large, download separately
backend/models/*.pt
backend/models/*.onnx
backend/models/*.tflite
backend/models/*.weights
!backend/models/.gitkeep

# ===== ENVIRONMENT FILES =====
.env
.env.local
.env.*.local
*.env

# ===== CREDENTIALS =====
# Never commit credentials or service accounts
service-account.json
*-key.json
*.pem
*.key
*.keystore
*.jks
key.properties

# ===== LOGS =====
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
doc/api/

# ===== MISC =====
# Test files and temporary data
test_images/
temp/
tmp/
*.tmp

# Coverage reports
coverage/
.coverage
htmlcov/

# Cloud Build
.gcloudignore

# macOS
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk